{
  "manifest_version": 3,
  "name": "File Processor",
  "version": "1.0",
  "action": {
    "default_popup": "code/index.html"
  },
  "background": {
    "service_worker": "code/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["libs/xlsx.full.min.js", "code/content.js"]
    }
  ],
  "permissions": ["storage"]
}
