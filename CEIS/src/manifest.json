{
  "manifest_version": 3,
  "name": "OnlineFill Oxfarm",
  "version": "1.0",
  "icons": {
    "16": "images/green_ribbon.png",
    "32": "images/green_ribbon.png",
    "48": "images/green_ribbon.png",
    "128": "images/green_ribbon.png"
  },

  "action": {
    "default_popup": "code/index.html"
  },
  "background": {
    "service_worker": "code/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["libs/xlsx.full.min.js", "code/content.js"]
    }
  ],
  "permissions": ["storage"]
}
